KC_cleaned1 <- KC_cleaned |>
mutate(across(starts_with("Expiration_"), as.character)) |>
rowwise() |>
mutate(
expiration_date = {
vals <- c_across(starts_with("Expiration_"))
# Trim whitespace and ignore NA
vals <- vals[!is.na(vals)]
# check for any text containing "life" or "indefinite"
life_vals <- vals[str_detect(vals, regex("life|indefinite", ignore_case = TRUE))]
if(length(life_vals) > 0) {
"Life/Indefinite"  # pick Life/Indefinite if any column has it
} else {
# extract 4-digit years from remaining text
years <- str_extract(vals, "\\b\\d{4}\\b")
years <- as.integer(years)
if(all(is.na(years))) NA_integer_ else max(years, na.rm = TRUE)
}
}
) |>
ungroup()
KC_cleaned1 <- KC_cleaned |>
mutate(across(starts_with("Expiration_"), as.character)) |>
rowwise() |>
mutate(
expiration_date = {
vals <- c_across(starts_with("Expiration_"))
# remove NAs
vals <- vals[!is.na(vals)]
# if no values remain, return NA
if(length(vals) == 0) {
NA_character_
} else {
# check for any text containing "life" or "indefinite"
life_vals <- vals[str_detect(vals, regex("life|indefinite", ignore_case = TRUE))]
if(length(life_vals) > 0) {
"Life/Indefinite"
} else {
# extract 4-digit years
years <- str_extract(vals, "\\b\\d{4}\\b")
years <- as.integer(years)
if(length(years) == 0 || all(is.na(years))) NA_integer_ else max(years, na.rm = TRUE)
}
}
}
) |>
ungroup()
KC_cleaned1 <- KC_cleaned |>
mutate(across(starts_with("Expiration_"), as.character)) |>
rowwise() |>
mutate(
expiration_date = {
vals <- c_across(starts_with("Expiration_"))
# remove NAs and blanks
vals <- vals[!is.na(vals) & vals != ""]
if(length(vals) == 0) {
NA_character_  # empty row
} else if(any(str_detect(vals, regex("life|indefinite", ignore_case = TRUE)))) {
"Life/Indefinite"
} else {
# extract 4-digit years
years <- as.integer(str_extract(vals, "\\b\\d{4}\\b"))
years <- years[!is.na(years)]
if(length(years) == 0) NA_character_ else as.character(max(years))
}
}
) |>
ungroup()
View(KC_cleaned1)
