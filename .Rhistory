KC_cleaned <- KC %>% mutate(county = "King",
contractnew_flag = 0,
working_id = ifelse(str_starts(kc_id, "SH_"), str_sub(kc_id, 1, 7), NA),
full_address = str_c(full_address,', ',city,', WA ',zip),
policy = pmap_chr(
list(FundingSource, HousingCovenant_A, HousingCovenant_B, HousingCovenant_C),
~ str_c(na_if(c(...), ""), collapse = "; ")),
# replace blanks with NA first
across(starts_with("Expiration_"), ~ na_if(., "")),
# convert to numeric
across(starts_with("Expiration_"), as.numeric),
# take the maximum across columns row-wise
expiration_date = do.call(pmax, c(across(starts_with("Expiration_")), na.rm = TRUE)))
KC_cleaned1 <- KC_cleaned |>
rowwise() |>  # row-wise is necessary because each row has multiple Expiration_ fields
mutate(
expiration_date = {
vals <- c_across(starts_with("Expiration_")) # grab all Expiration_ columns
# check for "life" / "indefinite"
if(any(str_detect(vals, regex("life|indefinite", ignore_case = TRUE)))) {Inf}
else {# extract 4-digit numbers from text
years <- str_extract(vals, "\\b\\d{4}\\b")  # grab any 4-digit number
years <- as.integer(years)  # convert to numeric
if(all(is.na(years))) NA_integer_ else max(years, na.rm = TRUE)
}
}
)
