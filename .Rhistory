# Create new fields & clean address field
KC_cleaned <- KC %>%
mutate(
county = "King",
contractnew_flag = 0,
working_id = ifelse(str_starts(kc_id, "SH_"), str_sub(kc_id, 1, 7), NA),
full_address = str_c(full_address, ', ', city, ', WA ', zip)
) %>%
# replace blanks/whitespace with NA
mutate(across(
c(FundingSource, HousingCovenant_A, HousingCovenant_B, HousingCovenant_C),
~ na_if(str_trim(.), "")
)) %>%
# unite into policy, removing original columns
unite(
col = "policy",
FundingSource, HousingCovenant_A, HousingCovenant_B, HousingCovenant_C,
sep = "; ",
na.rm = TRUE,
remove = TRUE  # default, explicitly stated
) %>%
# if policy ended up as empty string, convert to NA
mutate(policy = na_if(policy, "")) %>%
select(-c(City, ProjectType)) %>%
add_cleaned_addresses()
View(KC_cleaned)
