library(tidyverse)
library(readxl)
library(janitor)
library(data.table)
## 1) Set variables ---------------------------------------------------------------------
setwd("C:/Users/eclute/GitHub/irhd")
WSHFC_path <- "J:/Projects/IncomeRestrictedHsgDB/2024 vintage/Data/"
WSHFC_raw <- read_xlsx(paste0(WSHFC_path, "WSHFC - PSRC_Report_2024 (as of 9-24-25).xlsx"))
vintage_year_cleaning_script = "2024"
irhd_2024 <- "./reconcile_2024_IRHD.R"
cols_to_redact <- c(
"project_name",
"property_name",
"property_owner",
"developer",
"manager",
"reported_address",
"x_coord",
"y_coord",
"full_address",
"cleaned_address",
"jurisdiction_location",
"GeoCode_Lat",
"GeoCode_Long")
to_redact <- WSHFC_raw %>%
filter(County %in% c("Snohomish", "Pierce", "Kitsap")) %>%
group_by(SiteKey) %>%
filter(
n() == 1,
Funder == "Commerce") %>%
ungroup() %>%
rename(property_id = SiteKey)
review_missing_ids <- IRHD_clean %>%
filter(
county %in% c("Pierce", "Snohomish", "Kitsap"),
funding_sources == "Commerce", #Commerce is the only funder
is.na(property_id)) # missing the WSHFC provided key field
# Identify Commerce funded properties that are missing the WSHFC key field (SiteKey or property_id)
source(irhd_2024)
review_missing_ids <- IRHD_clean %>%
filter(
county %in% c("Pierce", "Snohomish", "Kitsap"),
funding_sources == "Commerce", #Commerce is the only funder
is.na(property_id)) # missing the WSHFC provided key field
View(review_missing_ids)
View(to_redact)
# Assumptions
library(readxl)
library(janitor)
library(data.table)
library(dplyr)
library(magrittr)
library(stringr)
vintage_year <- 2024
setwd("C:/Users/eclute/GitHub/irhd")
bha_raw <- "J:/Projects/IncomeRestrictedHsgDB/2023 vintage/Review Files Recieved/IRHD_review_kitsap_bremertonhousingauthority.xlsx"
hasco_raw <- "J:/Projects/IncomeRestrictedHsgDB/2023 vintage/Review Files Recieved/IRHD_review_snohomish.xlsx"
# Pull in data
bha <- read_excel(bha_raw, sheet = 3)
hasco <- read_excel(hasco_raw, sheet = 3)
View(bha)
View(hasco)
redact_rows <- IRHD_clean$property_id %in% to_redact$property_id |
IRHD_clean$working_id %in% review_missing_ids$working_id
IRHD_redacted <- IRHD_clean %>%
mutate(
across(
all_of(cols_to_redact),
~ replace(
as.character(.x),
redact_rows,
"Redacted per RCW 43.185A.070")))
